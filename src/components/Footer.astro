---
const year = new Date().getFullYear();
---

<footer>
  <div class="container inner">
    <p class="big">Thanks for stopping by<span class="dot">.</span></p>
    <div class="row">
      <p>© {year} Luis Jiménez</p>
      <ul>
        <!-- TODO: Luis — replace with your real profiles -->
        <li><a href="https://github.com/yourusername">GitHub</a></li>
        <li><a href="https://www.linkedin.com/in/yourusername">LinkedIn</a></li>
        <li><a href="mailto:luis.jimenez23@gmail.com">Email</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(3rem, 6vw, 5rem) 2rem;
    margin-top: var(--space-section);
  }

  .big {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.05;
    margin-bottom: 2.5rem;
  }

  .dot {
    color: var(--accent);
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--paper) 25%, transparent);
    padding-top: 1.5rem;
  }

  .row p {
    margin: 0;
    color: color-mix(in srgb, var(--paper) 70%, transparent);
  }

  ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  a {
    color: var(--paper);
    font-weight: 700;
  }

  a:hover {
    color: var(--accent);
  }
</style>
