---
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: Luis — replace with your real profiles
const socials = [
  { label: 'Email', href: 'mailto:luis.jimenez23@gmail.com', handle: 'luis.jimenez23@gmail.com' },
  { label: 'GitHub', href: 'https://github.com/yourusername', handle: '@yourusername' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/yourusername', handle: '/in/yourusername' },
];
---

<BaseLayout title="Contact — Luis Jiménez">
  <section class="container intro-block">
    <p class="eyebrow">Contact</p>
    <h1>Say hi<span class="accent">.</span></h1>
    <p class="lede">
      Whether it's work, a project idea, or you just want to talk shop — my inbox
      is open.
    </p>
  </section>

  <section class="section">
    <div class="container split">
      <div class="socials">
        <h2>Find me</h2>
        <ul>
          {
            socials.map(({ label, href, handle }) => (
              <li>
                <span class="label">{label}</span>
                <a href={href}>{handle}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thanks"
      >
        <h2>Or write here</h2>
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <label>
          Name
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          Message
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn">Send it</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .intro-block {
    padding-block: clamp(4rem, 10vw, 6rem) 0;
  }

  .accent {
    color: var(--accent);
  }

  .lede {
    font-size: var(--text-lg);
    font-weight: 500;
    max-width: 42ch;
  }

  .split {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr));
    gap: 3rem;
    align-items: start;
  }

  .socials ul {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .socials .label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .socials a {
    font-size: var(--text-md);
    font-weight: 700;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow-soft);
  }

  form h2 {
    margin: 0;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-weight: 700;
  }

  input,
  textarea {
    font-family: var(--font-body);
    font-size: var(--text-md);
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
    color: var(--ink);
  }

  input:focus,
  textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .hidden {
    display: none;
  }

  .btn {
    align-self: flex-start;
  }
</style>
